---
import { getNewsArticles } from '@/lib/microcms';

const categoryColor: Record<string, string> = {
  'お知らせ':     'tag--navy',
  '物件情報':     'tag--gold',
  'コラム':       'tag--gray',
  'プレスリリース': 'tag--gray',
};

function formatDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
}

let newsItems: { date: string; category: string; title: string }[] = [];
try {
  const res = await getNewsArticles({ limit: 5 });
  newsItems = res.contents.map((item) => ({
    date: formatDate(item.publishedAt),
    category: item.category,
    title: item.title,
  }));
} catch {
  // microCMS 未設定またはエラー時は非表示
}
---

{newsItems.length > 0 && (
  <section class="section section--bg" id="news">
    <div class="container container--narrow">
      <div class="news__head">
        <span class="section-label">News</span>
        <h2 class="section-title">お知らせ</h2>
        <div class="divider divider--center"></div>
      </div>

      <ul class="news-list">
        {newsItems.map((item) => (
          <li class="news-item">
            <time class="news-item__date">{item.date}</time>
            <span class={`news-item__tag ${categoryColor[item.category] ?? 'tag--gray'}`}>
              {item.category}
            </span>
            <span class="news-item__title">{item.title}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .news__head {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .news-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .news-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .news-item__date {
    font-family: var(--font-sans-en);
    font-size: 0.78rem;
    color: var(--color-text-light);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .news-item__tag {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 0.15em 0.7em;
    flex-shrink: 0;
  }

  .tag--navy {
    background: var(--color-navy);
    color: var(--color-white);
  }

  .tag--gold {
    background: var(--color-gold);
    color: var(--color-white);
  }

  .tag--gray {
    background: transparent;
    color: var(--color-text-mid);
    border: 1px solid var(--color-border);
  }

  .news-item__title {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .news-item {
      gap: 0.5rem;
    }

    .news-item__title {
      width: 100%;
    }
  }
</style>
