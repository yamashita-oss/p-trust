---
interface Props {
  title: string;
  type: string;
  price: string;
  image?: string;
  slug: string;
}

const { title, type, price, image, slug } = Astro.props;
---

<article class="property-card">
  <a href={`/properties/${slug}`} class="property-card__inner">

    <div class="property-card__image-wrap">
      {image
        ? <img src={image} alt={title} class="property-card__img" width="400" height="260" loading="lazy" />
        : <div class="property-card__img-placeholder" aria-hidden="true">物件写真</div>
      }
      <span class="property-card__type">{type}</span>
    </div>

    <div class="property-card__body">
      <div class="property-card__title">{title}</div>
      <div class="property-card__price">{price}</div>
    </div>

  </a>
</article>

<style>
  .property-card {
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .property-card:hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-card);
  }

  .property-card__inner {
    display: block;
  }

  /* 画像 */
  .property-card__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .property-card__img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .property-card:hover .property-card__img {
    transform: scale(1.03);
  }

  .property-card__img-placeholder {
    height: 220px;
    background: linear-gradient(135deg, var(--color-navy-pale), var(--color-bg-warm));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }

  /* 物件種別バッジ */
  .property-card__type {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    background: var(--color-navy);
    color: var(--color-white);
  }

  /* テキスト */
  .property-card__body {
    padding: 1.2rem var(--space-md);
  }

  .property-card__title {
    font-family: var(--font-serif-ja);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  .property-card__price {
    font-family: var(--font-serif-en);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--color-navy);
    letter-spacing: 0.02em;
  }
</style>
