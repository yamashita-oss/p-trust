---
interface Props {
  title: string;
  type: string;
  price: string;
  image?: string;
  slug: string;
  pdfUrl?: string;
}

const { title, type, price, image, slug, pdfUrl } = Astro.props;
const isSoldOut = type === '完売';
---

<article class="property-card">
  <div class="property-card__inner">

    <div class="property-card__image-wrap">
      {image
        ? <img src={image} alt={title} class="property-card__img" width="400" height="260" loading="lazy" />
        : <div class="property-card__img-placeholder" aria-hidden="true">物件写真</div>
      }
      <span class:list={['property-card__type', { 'property-card__type--soldout': isSoldOut }]}>{type}</span>
    </div>

    <div class="property-card__body">
      <div class="property-card__title">{title}</div>
      <div class="property-card__price">{price}</div>
      {pdfUrl && (
        <a
          href={pdfUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="property-card__pdf"
          aria-label={`${title}のPDF資料を開く`}
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 1h7l3 3v9H2V1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
            <path d="M9 1v3h3" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
            <path d="M4 7h6M4 9.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          PDF資料を見る
        </a>
      )}
    </div>

  </div>
</article>

<style>
  .property-card {
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .property-card:hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-card);
  }

  .property-card__inner {
    display: block;
    cursor: default;
  }

  /* 画像 */
  .property-card__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .property-card__img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .property-card:hover .property-card__img {
    transform: scale(1.03);
  }

  .property-card__img-placeholder {
    height: 220px;
    background: linear-gradient(135deg, var(--color-navy-pale), var(--color-bg-warm));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }

  /* 物件種別バッジ */
  .property-card__type {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    background: var(--color-navy);
    color: var(--color-white);
  }

  .property-card__type--soldout {
    background: #C0392B;
  }

  /* テキスト */
  .property-card__body {
    padding: 1.2rem var(--space-md);
  }

  .property-card__title {
    font-family: var(--font-casual-ja);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    letter-spacing: 0.03em;
    line-height: 1.5;
  }

  .property-card__price {
    font-family: var(--font-casual-ja);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--color-navy);
    letter-spacing: 0.02em;
  }

  .property-card__pdf {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    font-family: var(--font-sans-ja);
    color: var(--color-gold);
    border: 1px solid var(--color-gold);
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
    transition: background var(--transition), color var(--transition);
    text-decoration: none;
  }

  .property-card__pdf:hover {
    background: var(--color-gold);
    color: var(--color-white);
  }
</style>
