---
const services = [
  '売買仲介',
  '資産運用コンサルティング',
  '賃貸・管理',
  '相続・贈与',
];

const company = [
  { label: '会社概要', href: '/about' },
  { label: '代表メッセージ', href: '/about#message' },
  { label: 'アクセス', href: '/about#access' },
  { label: '採用情報', href: '/recruit' },
];

const info = [
  { label: '不動産購入ガイド', href: '/guide/buy' },
  { label: '売却の流れ', href: '/guide/sell' },
  { label: 'よくある質問', href: '/faq' },
  { label: 'お知らせ', href: '/news' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__inner">
      <!-- ブランド -->
      <div class="footer__brand">
        <a href="/" class="footer__brand-link" aria-label="P-TRUST トップページ">
          <img src="/images/logo.svg" alt="P-TRUST" class="footer__logo-img" width="80" height="67" />
        </a>
        <p class="footer__tagline">
          信頼と誠実を軸に、<br />
          お客様の大切な資産と暮らしを守る<br />
          不動産のパートナーであり続けます。
        </p>
        <address class="footer__address">
          〒157-0077<br />
          東京都世田谷区鎌田3-18-15 ロフティー玉川<br />
          TEL: <a href="tel:0368057608">03-6805-7608</a>
          &nbsp;/&nbsp;
          FAX: 03-6805-7609
        </address>
      </div>

      <!-- サービス -->
      <div>
        <div class="footer__nav-title">Services</div>
        <ul class="footer__nav-list">
          {services.map((s) => (
            <li><a href="/services">{s}</a></li>
          ))}
        </ul>
      </div>

      <!-- 会社情報 -->
      <div>
        <div class="footer__nav-title">Company</div>
        <ul class="footer__nav-list">
          {company.map(({ label, href }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- お役立ち情報 -->
      <div>
        <div class="footer__nav-title">Information</div>
        <ul class="footer__nav-list">
          {info.map(({ label, href }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <small>© {currentYear} 株式会社ピートラスト. All rights reserved.</small>
      <div class="footer__legal">
        <a href="/privacy">プライバシーポリシー</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #111827;
    color: var(--color-white);
    padding: var(--space-xl) 0 var(--space-md);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .footer__brand-link {
    display: inline-flex;
  }

  .footer__logo-img {
    height: 56px;
    width: auto;
    object-fit: contain;
    filter: invert(1) brightness(2);
    opacity: 0.85;
  }

  .footer__tagline {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.9;
    margin-top: var(--space-sm);
  }

  .footer__address {
    font-style: normal;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    line-height: 2;
    margin-top: var(--space-sm);
  }

  .footer__address a {
    color: inherit;
  }

  .footer__nav-title {
    font-family: var(--font-sans-en);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    margin-bottom: var(--space-sm);
  }

  .footer__nav-list {
    list-style: none;
  }

  .footer__nav-list li {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    padding: 0.3rem 0;
  }

  .footer__nav-list a {
    transition: color var(--transition);
  }

  .footer__nav-list a:hover {
    color: var(--color-white);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--space-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .footer__legal {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .footer__legal a {
    transition: color var(--transition);
  }

  .footer__legal a:hover {
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 1024px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
    }
  }

  @media (max-width: 600px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
