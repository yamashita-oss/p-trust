---
const navLinks = [
  { label: 'サービス案内', href: '/#services' },
  { label: '物件情報',     href: '/properties' },
  { label: '会社概要',     href: '/#company' },
  { label: 'アクセス',     href: '/#access' },
  { label: 'お問い合わせ', href: '/contact' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__inner">
      <!-- ブランド -->
      <div class="footer__brand">
        <a href="/" class="footer__brand-link" aria-label="P-TRUST トップページ">
          <img src="/images/P-TRUST-5.svg" alt="P-TRUST" class="footer__logo-img" width="80" height="67" />
        </a>
        <p class="footer__tagline">
          信頼と誠実を軸に、<br />
          お客様の大切な資産と暮らしを守る<br />
          不動産のパートナーであり続けます。
        </p>
        <address class="footer__address">
          〒157-0077<br />
          東京都世田谷区鎌田3-18-15 ロフティー玉川<br />
          <a href="mailto:yamashita@ptrust-web.com">yamashita@ptrust-web.com</a>
        </address>
      </div>

      <!-- ナビゲーション -->
      <div>
        <div class="footer__nav-title">Navigation</div>
        <ul class="footer__nav-list">
          {navLinks.map(({ label, href }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <small>© {currentYear} 株式会社ピートラスト. All rights reserved.</small>
      <div class="footer__legal">
        <a href="/privacy">プライバシーポリシー</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1A100A;
    color: var(--color-white);
    padding: var(--space-xl) 0 var(--space-md);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .footer__brand-link {
    display: inline-flex;
  }

  .footer__logo-img {
    height: 56px;
    width: auto;
    object-fit: contain;
    filter: invert(1) brightness(2);
    opacity: 0.85;
  }

  .footer__tagline {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.9;
    margin-top: var(--space-sm);
  }

  .footer__address {
    font-style: normal;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    line-height: 2;
    margin-top: var(--space-sm);
  }

  .footer__address a {
    color: inherit;
  }

  .footer__nav-title {
    font-family: var(--font-sans-en);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    margin-bottom: var(--space-sm);
  }

  .footer__nav-list {
    list-style: none;
  }

  .footer__nav-list li {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    padding: 0.3rem 0;
  }

  .footer__nav-list a {
    transition: color var(--transition);
  }

  .footer__nav-list a:hover {
    color: var(--color-white);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--space-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .footer__legal {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .footer__legal a {
    transition: color var(--transition);
  }

  .footer__legal a:hover {
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }

  @media (max-width: 600px) {
    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
