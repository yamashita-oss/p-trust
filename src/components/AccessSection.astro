---
---

<section class="section" id="access">
  <div class="container">
    <div style="text-align:center; margin-bottom:var(--space-lg)">
      <span class="section-label">Access</span>
      <h2 class="section-title">アクセス</h2>
      <div class="divider divider--center"></div>
    </div>

    <div class="access__inner">
      <dl class="access__dl">
        <div class="access__dl-row">
          <dt>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M8 1.5C5.5 1.5 3.5 3.5 3.5 6C3.5 9.5 8 14.5 8 14.5C8 14.5 12.5 9.5 12.5 6C12.5 3.5 10.5 1.5 8 1.5Z" stroke="#2E1F0F" stroke-width="1.2"/>
              <circle cx="8" cy="6" r="1.5" stroke="#A86B44" stroke-width="1.2"/>
            </svg>
            所在地
          </dt>
          <dd>
            〒157-0077<br />
            東京都世田谷区鎌田3-18-15 ロフティー玉川
          </dd>
        </div>
        <div class="access__dl-row">
          <dt>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="6" stroke="#2E1F0F" stroke-width="1.2"/>
              <polyline points="8,4 8,8 10.5,10.5" stroke="#A86B44" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            最寄り駅
          </dt>
          <dd>東急田園都市線・大井町線「二子玉川」駅</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .access__inner {
    max-width: 480px;
    margin: 0 auto;
  }

  .access__dl {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
  }

  .access__dl-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-sm);
    align-items: baseline;
    width: 100%;
  }

  .access__dl-row dt {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text-mid);
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding-top: 0.1rem;
  }

  .access__dl-row dd {
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  .access__dl-row dd a {
    color: var(--color-navy);
    border-bottom: 1px solid var(--color-border);
    transition: var(--transition);
  }

  .access__dl-row dd a:hover {
    color: var(--color-gold);
    border-color: var(--color-gold);
  }

  @media (max-width: 480px) {
    .access__dl-row {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }

    .access__dl-row dt {
      font-size: 0.72rem;
      color: var(--color-text-light);
    }
  }
</style>
