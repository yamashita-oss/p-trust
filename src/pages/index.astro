---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import ServicesSection from '@/components/ServicesSection.astro';
import PropertyCard from '@/components/PropertyCard.astro';
import CompanySection from '@/components/CompanySection.astro';
import AccessSection from '@/components/AccessSection.astro';
import ContactSection from '@/components/ContactSection.astro';
import { getProperties } from '@/lib/microcms';

// microCMS から新着物件を3件取得
let featuredProperties: any[] = [];
try {
  const res = await getProperties({ limit: 3 });
  featuredProperties = res.contents;
} catch {
  featuredProperties = [
    { id: 'sample-1', title: 'グランドステージ用賀',    type: '売買', price: '8,500万円' },
    { id: 'sample-2', title: 'ライオンズ二子玉川',       type: '売買', price: '6,200万円' },
    { id: 'sample-3', title: '鎌田4丁目 一戸建て',       type: '売買', price: '1億2,000万円' },
  ];
}
---

<BaseLayout
  title="P-TRUST（ピートラスト）｜世田谷の不動産売買・仲介｜株式会社ピートラスト"
  description="P-TRUST（ピートラスト）は東京・世田谷を中心に不動産売買・仲介を専門とする株式会社ピートラストの公式サイトです。地域密着15年以上の実績で、物件購入・売却・資産運用をサポートします。"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'P-TRUST（ピートラスト）',
    alternateName: ['P-TRUST', 'ピートラスト', 'p-trust'],
    url: 'https://ptrust-web.com',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://ptrust-web.com/properties?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  }}
>
  <Hero />
  <ServicesSection />

  <!-- おすすめ物件 -->
  <section class="properties section" id="properties">
    <div class="container">
      <div class="properties__header">
        <span class="section-label">Properties</span>
        <h2 class="section-title">物件情報</h2>
        <div class="divider divider--center"></div>
        <a href="/properties" class="btn btn--outline">もっと見る</a>
      </div>

      <div class="properties__grid">
        {featuredProperties.map((p) => (
          <PropertyCard
            title={p.title}
            type={p.type}
            price={p.price}
            image={p.image?.url}
            slug={p.id}
            documentUrl={p.document?.url}
          />
        ))}
      </div>
    </div>
  </section>

  <CompanySection />
  <AccessSection />
  <ContactSection />
</BaseLayout>

<style>
  .properties__header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .properties__header .btn--outline {
    margin-top: var(--space-md);
  }

  .properties__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .properties__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .properties__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
