---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
---

<BaseLayout
  title="お問い合わせ | P-TRUST 株式会社ピートラスト"
  description="株式会社ピートラストへのお問い合わせはこちらから。不動産の購入・売却・運用など、どんなご相談もお受けしております。"
>
  <PageHeader
    label="Contact"
    title="お問い合わせ"
    breadcrumbs={[{ label: 'お問い合わせ' }]}
  />

  <section class="section" id="contact-form">
    <div class="container container--narrow">

      <div class="contact-intro">
        <p>
          不動産の購入・売却・賃貸・運用など、どんなご相談もお受けしております。<br />
          下記フォームに必要事項をご入力の上、送信してください。<br />
          通常<strong>1営業日以内</strong>にご返信いたします。
        </p>

        <div class="contact-direct">
          <div class="contact-direct__item">
            <span class="contact-direct__label">お急ぎの方はお電話で</span>
            <a href="tel:0368057608" class="contact-direct__link">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 3 Q3 2 4 2 L6.5 2 L7.5 5.5 L6 6.5 Q7 9 9 11 L10 9.5 L13.5 10.5 L13.5 13 Q13.5 14 12.5 14 Q6 14 3 3Z" stroke="currentColor" stroke-width="1.2" fill="none"/>
              </svg>
              03-6805-7608
            </a>
            <span class="contact-direct__note">平日 10:00〜18:00</span>
          </div>
        </div>
      </div>

      <!-- Netlify Forms: data-netlify="true" が必須 -->
      <form
        name="contact"
        method="POST"
        action="/thanks"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="contact-form"
        novalidate
      >
        <!-- Netlify が form-name を認識するための隠しフィールド -->
        <input type="hidden" name="form-name" value="contact" />
        <!-- スパム対策ハニーポット（非表示） -->
        <p class="hidden-field" aria-hidden="true">
          <label>この欄は入力しないでください: <input name="bot-field" /></label>
        </p>

        <div class="form-grid">

          <!-- お名前 -->
          <div class="form-field">
            <label for="name" class="form-label">
              お名前 <span class="form-required">必須</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              placeholder="例：山田 太郎"
              required
              autocomplete="name"
              aria-describedby="name-error"
            />
            <span class="form-error" id="name-error" aria-live="polite"></span>
          </div>

          <!-- メールアドレス -->
          <div class="form-field">
            <label for="email" class="form-label">
              メールアドレス <span class="form-required">必須</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="例：example@email.com"
              required
              autocomplete="email"
              aria-describedby="email-error"
            />
            <span class="form-error" id="email-error" aria-live="polite"></span>
          </div>

          <!-- 電話番号 -->
          <div class="form-field">
            <label for="phone" class="form-label">
              電話番号 <span class="form-optional">任意</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input"
              placeholder="例：090-0000-0000"
              autocomplete="tel"
              aria-describedby="phone-error"
            />
            <span class="form-error" id="phone-error" aria-live="polite"></span>
          </div>

          <!-- お問い合わせ種別 -->
          <div class="form-field">
            <label for="inquiry-type" class="form-label">
              お問い合わせ種別 <span class="form-required">必須</span>
            </label>
            <div class="form-select-wrap">
              <select
                id="inquiry-type"
                name="inquiry-type"
                class="form-select"
                required
                aria-describedby="inquiry-type-error"
              >
                <option value="" disabled selected>選択してください</option>
                <option value="不動産の購入について">不動産の購入について</option>
                <option value="不動産の売却について">不動産の売却について</option>
                <option value="賃貸・管理について">賃貸・管理について</option>
                <option value="資産運用・コンサルティングについて">資産運用・コンサルティングについて</option>
                <option value="その他">その他</option>
              </select>
              <svg class="form-select-arrow" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                <path d="M1 1L6 7L11 1" stroke="#8C96A8" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <span class="form-error" id="inquiry-type-error" aria-live="polite"></span>
          </div>

          <!-- メッセージ -->
          <div class="form-field form-field--full">
            <label for="message" class="form-label">
              お問い合わせ内容 <span class="form-required">必須</span>
            </label>
            <textarea
              id="message"
              name="message"
              class="form-textarea"
              rows="7"
              placeholder="ご相談内容・ご要望をできるだけ詳しくお書きください。"
              required
              aria-describedby="message-error"
            ></textarea>
            <span class="form-error" id="message-error" aria-live="polite"></span>
          </div>

          <!-- 個人情報の取り扱い -->
          <div class="form-field form-field--full">
            <div class="form-privacy" id="privacy-box">
              <p class="form-privacy__text">
                ご入力いただいた個人情報は、お問い合わせへの返答および弊社サービスのご案内のみに使用し、第三者への提供はいたしません。
              </p>
              <label class="form-checkbox">
                <input type="checkbox" id="agree" name="個人情報の取り扱いへの同意" value="同意する" required aria-describedby="agree-error" />
                <span class="form-checkbox__mark" aria-hidden="true"></span>
                <span class="form-checkbox__label">
                  <a href="/privacy" target="_blank" class="form-privacy-link">プライバシーポリシー</a>に同意する <span class="form-required">必須</span>
                </span>
              </label>
            </div>
            <span class="form-error" id="agree-error" aria-live="polite"></span>
          </div>

        </div>

        <div class="form-submit">
          <button type="submit" class="btn btn--primary btn--lg">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8H14M9 3L14 8L9 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            送信する
          </button>
          <p class="form-submit__note">※ 送信後、確認メールは自動送信されません。返信までしばらくお待ちください。</p>
        </div>

      </form>

    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================
     イントロ
     ============================================ */
  .contact-intro {
    margin-bottom: var(--space-lg);
  }

  .contact-intro p {
    font-size: 0.9rem;
    line-height: 2;
    color: var(--color-text-mid);
    margin-bottom: var(--space-md);
  }

  .contact-intro strong {
    color: var(--color-navy);
    font-weight: 600;
  }

  .contact-direct {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-navy-pale);
    border-left: 3px solid var(--color-gold);
  }

  .contact-direct__item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .contact-direct__label {
    font-size: 0.78rem;
    color: var(--color-text-mid);
    white-space: nowrap;
  }

  .contact-direct__link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans-en);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-navy);
    transition: color var(--transition);
  }

  .contact-direct__link:hover {
    color: var(--color-gold);
  }

  .contact-direct__note {
    font-size: 0.72rem;
    color: var(--color-text-light);
  }

  /* ============================================
     ハニーポット（スパム対策）
     ============================================ */
  .hidden-field {
    position: absolute;
    left: -9999px;
    height: 0;
    overflow: hidden;
  }

  /* ============================================
     フォーム
     ============================================ */
  .contact-form {
    position: relative;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md) var(--space-md);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  /* ラベル */
  .form-label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .form-required {
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--color-white);
    background: var(--color-navy);
    padding: 0.1em 0.5em;
    letter-spacing: 0.05em;
  }

  .form-optional {
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--color-text-light);
    border: 1px solid var(--color-border);
    padding: 0.1em 0.5em;
    letter-spacing: 0.05em;
  }

  /* インプット共通 */
  .form-input,
  .form-select,
  .form-textarea {
    font-family: var(--font-sans-ja);
    font-size: 0.9rem;
    color: var(--color-text);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    transition: border-color var(--transition), box-shadow var(--transition);
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    outline: none;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    border-color: var(--color-navy);
    box-shadow: 0 0 0 3px rgba(28, 43, 74, 0.08);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--color-text-light);
  }

  /* エラー状態 */
  .form-input--error,
  .form-select--error,
  .form-textarea--error {
    border-color: #C0392B;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.08);
  }

  .form-privacy--error {
    border-color: #C0392B;
  }

  .form-error {
    font-size: 0.75rem;
    color: #C0392B;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    min-height: 1.2em;
  }

  .form-error:not(:empty)::before {
    content: '';
    display: inline-block;
    width: 12px;
    height: 12px;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='6' cy='6' r='5.5' stroke='%23C0392B'/%3E%3Cpath d='M6 3.5V6.5' stroke='%23C0392B' stroke-linecap='round'/%3E%3Ccircle cx='6' cy='8.5' r='0.5' fill='%23C0392B'/%3E%3C/svg%3E");
    background-size: contain;
    flex-shrink: 0;
  }

  /* セレクトボックス */
  .form-select-wrap {
    position: relative;
  }

  .form-select {
    cursor: pointer;
    padding-right: 2.5rem;
  }

  .form-select-arrow {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  /* テキストエリア */
  .form-textarea {
    resize: vertical;
    min-height: 160px;
    line-height: 1.8;
  }

  /* ============================================
     個人情報・チェックボックス
     ============================================ */
  .form-privacy {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: var(--space-sm) var(--space-md);
    transition: border-color var(--transition);
  }

  .form-privacy__text {
    font-size: 0.78rem;
    color: var(--color-text-mid);
    line-height: 1.8;
    margin-bottom: var(--space-sm);
  }

  .form-checkbox {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    user-select: none;
  }

  .form-checkbox input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .form-checkbox__mark {
    width: 18px;
    height: 18px;
    border: 1px solid var(--color-border);
    background: var(--color-white);
    flex-shrink: 0;
    position: relative;
    transition: border-color var(--transition), background var(--transition);
  }

  .form-checkbox input[type="checkbox"]:checked + .form-checkbox__mark {
    background: var(--color-navy);
    border-color: var(--color-navy);
  }

  .form-checkbox input[type="checkbox"]:checked + .form-checkbox__mark::after {
    content: '';
    position: absolute;
    left: 3px;
    top: 7px;
    width: 10px;
    height: 5px;
    border-left: 2px solid white;
    border-bottom: 2px solid white;
    transform: rotate(-45deg) translateY(-3px);
  }

  .form-checkbox input[type="checkbox"]:focus-visible + .form-checkbox__mark {
    outline: 2px solid var(--color-navy);
    outline-offset: 2px;
  }

  .form-checkbox__label {
    font-size: 0.82rem;
    color: var(--color-text-mid);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* ============================================
     送信ボタン
     ============================================ */
  .form-privacy-link {
    color: var(--color-navy);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition), border-color var(--transition);
  }

  .form-privacy-link:hover {
    color: var(--color-gold);
    border-color: var(--color-gold);
  }

  .form-submit {
    margin-top: var(--space-lg);
    text-align: center;
  }

  .btn--lg {
    font-size: 1rem;
    padding: 1rem 3rem;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .form-submit__note {
    font-size: 0.72rem;
    color: var(--color-text-light);
    margin-top: var(--space-sm);
  }

  /* ============================================
     レスポンシブ
     ============================================ */
  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .form-field--full {
      grid-column: 1;
    }

    .contact-direct {
      flex-direction: column;
      gap: 0.5rem;
    }

    .btn--lg {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const form = document.querySelector('.contact-form') as HTMLFormElement;

  // ── バリデーションルール ─────────────────────────────
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const PHONE_RE = /^[\d\-+() ]{10,15}$/;

  function validateField(id: string): boolean {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
    const errorEl = document.getElementById(`${id}-error`) as HTMLElement;
    if (!el || !errorEl) return true;

    let message = '';

    if (id === 'name') {
      if (!el.value.trim()) message = 'お名前を入力してください。';
    } else if (id === 'email') {
      if (!el.value.trim()) {
        message = 'メールアドレスを入力してください。';
      } else if (!EMAIL_RE.test(el.value.trim())) {
        message = '正しいメールアドレス形式で入力してください。';
      }
    } else if (id === 'phone') {
      if (el.value.trim() && !PHONE_RE.test(el.value.trim())) {
        message = '正しい電話番号を入力してください（例：090-0000-0000）。';
      }
    } else if (id === 'inquiry-type') {
      if (!el.value) message = 'お問い合わせ種別を選択してください。';
    } else if (id === 'message') {
      if (!el.value.trim()) message = 'お問い合わせ内容を入力してください。';
    } else if (id === 'agree') {
      const checkbox = el as HTMLInputElement;
      if (!checkbox.checked) message = 'プライバシーポリシーへの同意が必要です。';
    }

    errorEl.textContent = message;

    // 入力要素にエラークラスを付け外し
    if (id === 'agree') {
      const privacyBox = document.getElementById('privacy-box');
      privacyBox?.classList.toggle('form-privacy--error', !!message);
    } else if (el.tagName === 'SELECT') {
      el.classList.toggle('form-select--error', !!message);
    } else if (el.tagName === 'TEXTAREA') {
      el.classList.toggle('form-textarea--error', !!message);
    } else {
      el.classList.toggle('form-input--error', !!message);
    }

    return !message;
  }

  function validateAll(): boolean {
    const fields = ['name', 'email', 'phone', 'inquiry-type', 'message', 'agree'];
    const results = fields.map(validateField);
    return results.every(Boolean);
  }

  // ── blur（フォーカスアウト）時にリアルタイム検証 ───────
  ['name', 'email', 'phone', 'inquiry-type', 'message'].forEach((id) => {
    const el = document.getElementById(id);
    el?.addEventListener('blur', () => validateField(id));
    el?.addEventListener('input', () => {
      // エラー表示中のみリアルタイムで再検証（打ち消し）
      const errorEl = document.getElementById(`${id}-error`);
      if (errorEl?.textContent) validateField(id);
    });
  });

  // チェックボックスは change で即検証
  document.getElementById('agree')?.addEventListener('change', () => validateField('agree'));

  // ── 送信時バリデーション ────────────────────────────
  form?.addEventListener('submit', (e) => {
    const valid = validateAll();
    if (!valid) {
      e.preventDefault();
      // 最初のエラー要素までスクロール
      const firstError = form.querySelector('.form-error:not(:empty)') as HTMLElement;
      if (firstError) {
        firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }
  });
</script>
